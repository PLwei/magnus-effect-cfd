FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];
internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 0;
    }
    outlet
    {
        type            calculated;
        value           uniform 0;
    }
    top
    {
        type            symmetry;
    }
    bottom
    {
        type            symmetry;
    }
    cylinder
    {
        type            nutkWallFunction;
        value           uniform 0;
    }
    midSpan
    {
        type            symmetry;
    }
    farField
    {
        type            calculated;
        value           uniform 0;
    }
    undefined
    {
        type            calculated;
        value           uniform 0;
    }
}

